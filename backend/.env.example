# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=soroban_multisig
DB_USER=postgres
DB_PASSWORD=postgres

# Soroban
SOROBAN_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
TREASURY_CONTRACT_ID=
GOVERNANCE_CONTRACT_ID=
REGISTRY_CONTRACT_ID=

# Features
ENABLE_INDEXER=true

# Notifications
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
